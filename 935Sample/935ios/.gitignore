# ==============================================================================
# 1. Standard Node/JavaScript Ignores
# ==============================================================================
node_modules/
*.log
.DS_Store
Thumbs.db
.vscode/
.idea/

# ==============================================================================
# 2. GitHub Actions / Appetize Build Artifacts
# ==============================================================================
*.zip
build/

# ==============================================================================
# 3. Native iOS Heavyweight Dependencies & Caches (Blocks the 1,000+ files)
# ==============================================================================
ios/App/Pods/
ios/App/.symlinks/
ios/App/DevelopmentPods/
ios/App/build/
ios/App/output/
DerivedData/

# Ignore user-specific Xcode layouts, workspaces, and states
ios/App/App.xcworkspace/xcuserdata/
ios/App/App.xcodeproj/xcuserdata/
ios/App/App.xcworkspace/xcshareddata/
ios/App/App.xcodeproj/project.xcworkspace/
*.pbxuser
*.mode1v3
*.mode2v3
*.perspectivev3

# Ignore Cordova plugin artifacts generated by Capacitor
ios/App/capacitor-cordova-ios-plugins/

# ==============================================================================
# 4. Web Assets Copied into iOS (Generated dynamically by 'npx cap sync')
# ==============================================================================
ios/App/public/
ios/App/App/public/

# Ignore automatically generated native platform configurations
ios/App/App/capacitor.config.json
ios/App/App/config.xml
ios/capacitor-cordova-ios-plugins